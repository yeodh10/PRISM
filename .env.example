# === PRISM 환경변수 템플릿 ===
# 이 파일을 복사해 .env 로 만들고 실제 키를 채우세요. .env 는 절대 커밋 금지(.gitignore 처리됨).
#   cp .env.example .env   (PowerShell: Copy-Item .env.example .env)

# Anthropic API 키 — https://console.anthropic.com/ 에서 발급
ANTHROPIC_API_KEY=sk-ant-여기에_실제_키

# (선택) 기본값 오버라이드
# CLAUDE_MODEL=claude-sonnet-4-6        # opus-4-8 기본. 비용↓: sonnet-4-6 / haiku-4-5
# CLAUDE_EFFORT=low                     # adaptive thinking 깊이: low|medium|high|xhigh|max
# EMBEDDING_MODEL=jhgan/ko-sroberta-multitask
# TOP_K=4
# CORS_ALLOW_ORIGINS=https://your-domain.com   # 운영 시 배포 도메인으로 제한
# NEWS_RSS_URL=https://www.dailysecu.com/rss/allArticle.xml
# NEWS_CACHE_TTL=1800
